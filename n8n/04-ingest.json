          }
        ]
      ]
    },
    "Mark Written": {
      "main": [
        [
          {
            "node": "Check Expansion",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Expansion": {
      "main": [
        [
          {
            "node": "Should Expand?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Should Expand?": {
      "main": [
        [
          {
            "node": "Queue Next Company",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Queue Next Company": {
      "main": [
        []
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    "supplylens"
  ],
  "notes": "Pipeline 04: Ingest\n- Picks accepted claims (confidence >= threshold)\n- MERGE nodes + relationships into Neo4j via REST API\n- confidence + contested + source stored on every edge\n- Queues newly discovered companies at next tier\n- Stops at max_tier_depth (default 3)\n- Triggers 02-discover for next tier companies"
}